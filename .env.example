# OpenWebUI image and host mapping
OPEN_WEBUI_IMAGE=ghcr.io/open-webui/open-webui:main
OPEN_WEBUI_CONTAINER_NAME=open-webui
OPEN_WEBUI_BIND_HOST=172.17.0.1
OPEN_WEBUI_PORT=3001
OPEN_WEBUI_DATA_PATH=./data/openwebui
WEBUI_AUTH=False

# Qdrant storage
QDRANT_IMAGE=qdrant/qdrant:latest
QDRANT_CONTAINER_NAME=qdrant
QDRANT_DATA_PATH=./data/qdrant

# RAG service build/runtime
RAG_API_BUILD_CONTEXT=./rag-api
RAG_API_CONTAINER_NAME=rag-api
FEISHU_BOT_BUILD_CONTEXT=./feishu-bot
FEISHU_BOT_CONTAINER_NAME=feishu-bot
RAG_INDEX_SCHEDULER_CONTAINER_NAME=rag-index-scheduler
RESTART_POLICY=unless-stopped
INDEX_SCHEDULE_INTERVAL_SECONDS=600

# Host Kodbox path and mount target inside rag-api
KB_HOST_PATH=/data/kodbox/files
KB_ROOT=/kb
STATE_DIR=/var/lib/rag-api

# File filters
KB_EXTENSIONS=.txt,.text,.md,.markdown,.rst,.log,.ini,.cfg,.conf,.yaml,.yml,.json,.xml,.html,.htm,.css,.js,.ts,.tsx,.jsx,.py,.go,.java,.c,.cc,.cpp,.h,.hpp,.rs,.sh,.sql,.csv,.tsv,.pdf,.doc,.docx,.xls,.xlsx
KB_EXCLUDE_PATTERNS=/recycle/,/cache/,/thumb/

# Indexing and chunking
INDEX_BATCH_SIZE=32
EMBEDDING_BATCH_SIZE=128
QDRANT_UPSERT_RETRIES=4
QDRANT_UPSERT_RETRY_DELAY_SECONDS=2.0
CHUNK_SIZE=500
CHUNK_OVERLAP=80
EXCEL_MAX_ROWS_PER_SHEET=5000
EXCEL_MAX_COLUMNS_PER_ROW=200
EXCEL_INCLUDE_EMPTY_ROWS=false

# Retrieval and answer length
RETRIEVAL_LIMIT=2
MIN_RETRIEVAL_SCORE=0.35
MAX_CONTEXT_CHARS=1200
MAX_OUTPUT_TOKENS=384

# Qdrant connection
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=kodbox_kb

# Downstream OpenAI-compatible chat model
OPENAI_BASE_URL=https://your-openai-compatible-api/v1
OPENAI_API_KEY=replace-with-your-api-key
CHAT_MODEL=replace-with-your-chat-model

# Embeddings: set EMBEDDING_PROVIDER=openai to offload embeddings remotely
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
EMBEDDING_BASE_URL=
EMBEDDING_API_KEY=
EMBEDDING_MODEL_REMOTE=text-embedding-3-small

# PDF extraction backend: pymupdf is faster, pypdf is lighter fallback
PDF_EXTRACTOR=pymupdf

# Feishu bot adapter
FEISHU_BOT_BIND_HOST=127.0.0.1
FEISHU_BOT_PORT=8088
FEISHU_BASE_URL=https://open.feishu.cn
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_VERIFICATION_TOKEN=
FEISHU_SIGNING_SECRET=
FEISHU_RAG_API_BASE=http://rag-api:8000
FEISHU_RAG_MODEL=rag-model
FEISHU_RAG_API_KEY=feishu-bot
FEISHU_REPLY_PREFIX=
FEISHU_ALLOWED_CHAT_TYPES=p2p
FEISHU_MESSAGE_MAX_CHARS=4000
FEISHU_HTTP_TIMEOUT_SECONDS=120
